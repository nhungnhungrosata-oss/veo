# LƯU Ý: App đang chạy frontend bằng Vite, biến môi trường muốn browser đọc được PHẢI có tiền tố VITE_.
# Thứ tự fallback hiện tại: Gemini theo thứ tự dưới đây → DeepSeek → OpenAI.

# Google Gemini Keys - có thể nhập nhiều key free trước, key paid sau
VITE_GEMINI_API_KEY=your_free_key_here
VITE_GEMINI_API_KEY_1=your_free_key_1_here
VITE_GEMINI_API_KEY_2=your_free_key_2_here
VITE_GEMINI_API_KEY_3=your_free_key_3_here
VITE_GEMINI_API_KEY_4=your_free_key_4_here
VITE_GEMINI_API_KEY_5=your_free_key_5_here
VITE_GEMINI_API_KEY_PAID=your_paid_key_here

# DeepSeek Keys - sẽ chạy sau khi toàn bộ Gemini key lỗi/hết quota
VITE_DEEPSEEK_API_KEY=sk-...
VITE_DEEPSEEK_API_KEY_1=sk-...
VITE_DEEPSEEK_API_KEY_2=sk-...
VITE_DEEPSEEK_MODEL=deepseek-v4-flash

# OpenAI Keys - fallback cuối cùng nếu DeepSeek cũng lỗi/hết tiền/hết quota
VITE_OPENAI_API_KEY=sk-...
VITE_OPENAI_API_KEY_1=sk-...
VITE_OPENAI_API_KEY_2=sk-...
VITE_OPENAI_MODEL=gpt-4o-mini
